<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools">

  <!-- Metro's appComponentFactory is out of sync with Robolectric's. Without this replacement we'd get failures
   for any SDK except 28, which defeats the point of the tests -->
  <application
    android:appComponentFactory="androidx.core.app.AppComponentFactory"
    tools:replace="android:appComponentFactory">

    <!-- Causes initialization issues with Robolectric -->
    <receiver
      android:name="androidx.profileinstaller.ProfileInstallReceiver"
      tools:node="remove" />

  </application>

</manifest>
